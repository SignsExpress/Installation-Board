{
  "name": "sx-installation-board",
  "version": "1.0.0",
  "private": true,
  "description": "Shared installation board with rolling calendar view, bank holidays, and live updates.",
  "scripts": {
    "dev": "concurrently \"vite --host 0.0.0.0\" \"node server/index.js\"",
